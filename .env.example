# ── Database ──────────────────────────────────────────────────────────────
# Railway: add Postgres plugin, then set DATABASE_URL = ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── Payload CMS ───────────────────────────────────────────────────────────
# Generate at: https://generate-secret.vercel.app/32
PAYLOAD_SECRET=replace-with-a-long-random-string

# ── Next.js ───────────────────────────────────────────────────────────────
# Required for Server Actions in production (Payload admin). Generate 32-char key.
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=replace-with-32-char-key
NEXT_PUBLIC_SERVER_URL=https://thetruckersedge.com

# ── AI Viral News (optional) ───────────────────────────────────────────────
# xAI API key from https://console.x.ai/
XAI_API_KEY=
# Secret for cron job auth (Bearer token or x-cron-secret header)
CRON_SECRET=
