# ── Database ──────────────────────────────────────────────────────────────
# Railway auto-provides this when you add a PostgreSQL plugin to your project.
# Copy the "DATABASE_URL" value from the Railway PostgreSQL plugin dashboard.
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── Payload CMS ───────────────────────────────────────────────────────────
# Generate a strong random string (32+ chars). Keep this secret.
# You can generate one at: https://generate-secret.vercel.app/32
PAYLOAD_SECRET=replace-with-a-long-random-string

# ── Next.js ───────────────────────────────────────────────────────────────
# Set to your actual domain once deployed.
NEXT_PUBLIC_SERVER_URL=https://thetruckersedge.com

# ── Email (optional, for lead capture) ───────────────────────────────────
# MailerLite API key — get this from your MailerLite account settings.
# MAILERLITE_API_KEY=your_mailerlite_api_key
# MAILERLITE_GROUP_ID=your_group_id
