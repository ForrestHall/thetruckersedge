# ── Database ──────────────────────────────────────────────────────────────
# Railway: add Postgres plugin, then set DATABASE_URL = ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── Payload CMS ───────────────────────────────────────────────────────────
# Generate at: https://generate-secret.vercel.app/32
PAYLOAD_SECRET=replace-with-a-long-random-string

# ── Next.js ───────────────────────────────────────────────────────────────
# Required for Server Actions in production (Payload admin). Generate 32-char key.
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=replace-with-32-char-key
NEXT_PUBLIC_SERVER_URL=https://thetruckersedge.com

# ── AI Viral News (optional) ───────────────────────────────────────────────
# xAI API key from https://console.x.ai/
XAI_API_KEY=
# Secret for cron job auth (Bearer token or x-cron-secret header)
CRON_SECRET=

# ── Warranty Quote (optional) ───────────────────────────────────────────────
# Resend API key from https://resend.com
RESEND_API_KEY=
# Email that receives warranty quote leads (your inbox)
ADMIN_EMAIL=your-email@example.com
# "From" address — must be allowed by Resend:
# • Production: verify your domain in Resend, then use e.g. noreply@yourdomain.com
# • Testing only: use onboarding@resend.dev — you can ONLY send TO the same email as your Resend account
WARRANTY_FROM_EMAIL=onboarding@resend.dev

# ── Mechanic hosted pages (Stripe subscriptions) ───────────────────────────
# Dashboard: https://dashboard.stripe.com — create a recurring Price, then copy IDs.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
# Webhook signing secret from Stripe CLI or Dashboard (endpoint: /api/mechanic-subscription/webhook)
STRIPE_WEBHOOK_SECRET=
